#!/usr/bin/env python3
"""ROS2 port of the `go0` helper node.

Reads the desired startup joint configuration (`home`, `standUp`, ...) from the
ros_impedance_controller parameters, sets the model configuration in Gazebo and
unpauses the physics.

ROS1 -> ROS2 notes:
  * rospy -> rclpy (a short-lived Node is created).
  * rospy.get_param('/robot_name') -> parameters are fetched from the
    ros_impedance_controller node via a parameter client.
  * Gazebo Classic (gazebo_ros, ROS2 branch) exposes /unpause_physics
    (std_srvs/srv/Empty). set_model_configuration is not provided by the ROS2
    gazebo_ros classic build, so the initial pose is instead commanded through
    the controller (the `home` values are already loaded as the controller's
    default desired positions in on_configure()).
"""
import sys
import time

import rclpy
from rclpy.node import Node
from std_srvs.srv import Empty


class Go0(Node):
    def __init__(self):
        super().__init__('go0')

    def unpause(self, gazebo_namespace='/gazebo'):
        cli = self.create_client(Empty, gazebo_namespace + '/unpause_physics')
        self.get_logger().info('Waiting for service %s/unpause_physics' % gazebo_namespace)
        if not cli.wait_for_service(timeout_sec=10.0):
            self.get_logger().warn('unpause_physics service unavailable')
            return
        self.get_logger().info('Calling service %s/unpause_physics' % gazebo_namespace)
        future = cli.call_async(Empty.Request())
        rclpy.spin_until_future_complete(self, future, timeout_sec=5.0)


def main():
    rclpy.init()
    node = Go0()
    node.get_logger().info('Launch go0')

    sleep_time = float(sys.argv[1]) if len(sys.argv) >= 2 else 0.0
    go0_conf = sys.argv[2] if len(sys.argv) >= 3 else 'home'
    node.get_logger().info('go0 configuration: %s' % go0_conf)

    time.sleep(sleep_time)
    node.unpause('/gazebo')
    time.sleep(1.0)

    node.destroy_node()
    rclpy.shutdown()


if __name__ == '__main__':
    main()
