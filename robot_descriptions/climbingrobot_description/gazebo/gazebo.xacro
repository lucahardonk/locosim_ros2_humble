<?xml version="1.0"?>
<!--
  Gazebo Classic (gazebo11) + ros2_control description for climbingrobot2.

  ROS1 -> ROS2 changes (ported from gazebo/gazebo.urdf.xacro):
    * libgazebo_ros_control.so  ->  libgazebo_ros2_control.so
      (robotNamespace/robotSimType/legacyModeNS/controlPeriod removed; the
       plugin now takes a <parameters> tag pointing at the controller_manager
       YAML and reads the URDF from the robot_state_publisher node).
    * The controller update rate previously set through <controlPeriod> is now
      the controller_manager `update_rate` in
      config/ros_impedance_controller_climbingrobot2.yaml.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="task_period" default="0.001"/>
  <xacro:arg name="robot_name" default="climbingrobot2"/>

  <!-- ros2_control system + embedded controller_manager -->
  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <parameters>$(find climbingrobot_description)/config/ros_impedance_controller_$(arg robot_name).yaml</parameters>
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
    </plugin>
  </gazebo>
</robot>
